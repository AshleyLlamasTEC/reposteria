DROP PROCEDURE IF EXISTS sp_checkout_cart;

DELIMITER $$

CREATE PROCEDURE sp_checkout_cart(
    IN p_user_id BIGINT
)
BEGIN
    DECLARE v_cart_id BIGINT;
    DECLARE v_total DECIMAL(12,2);
    DECLARE v_order_id BIGINT;
    DECLARE v_items INT;

    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        ROLLBACK;
        RESIGNAL;
    END;

    START TRANSACTION;

    -- Buscar carrito activo
    SELECT id, total_amount
    INTO v_cart_id, v_total
    FROM carts
    WHERE user_id = p_user_id
      AND status = 'active'
    LIMIT 1;

    IF v_cart_id IS NULL THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'No existe carrito activo';
    END IF;

    -- Verificar que tenga items
    SELECT COUNT(*)
    INTO v_items
    FROM cart_items
    WHERE cart_id = v_cart_id;

    IF v_items = 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'El carrito está vacío';
    END IF;

    -- Crear orden
    INSERT INTO orders(
        order_number,
        user_id,
        total_amount,
        state,
        created_at,
        updated_at
    )
    VALUES(
        CONCAT('ORD-', UNIX_TIMESTAMP()),
        p_user_id,
        v_total,
        'pending',
        NOW(),
        NOW()
    );

    SET v_order_id = LAST_INSERT_ID();

    -- Copiar items a order_items
    INSERT INTO order_items(
        order_id,
        product_id,
        quantity,
        unit_price,
        subtotal,
        created_at,
        updated_at
    )
    SELECT
        v_order_id,
        product_id,
        quantity,
        unit_price,
        subtotal,
        NOW(),
        NOW()
    FROM cart_items
    WHERE cart_id = v_cart_id;

    -- Descontar stock
    UPDATE products p
    JOIN cart_items ci
        ON p.id = ci.product_id
    SET p.stock = p.stock - ci.quantity
    WHERE ci.cart_id = v_cart_id;

    -- Marcar carrito como completado
    UPDATE carts
    SET status = 'completed'
    WHERE id = v_cart_id;

    -- Limpiar carrito
    DELETE FROM cart_items
    WHERE cart_id = v_cart_id;

    COMMIT;

    -- Retornar datos al controlador
    SELECT
        v_order_id AS order_id,
        v_total AS total;

END$$

DELIMITER ;
